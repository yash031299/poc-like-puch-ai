# Puch AI Voice Server — Environment Variables
# Copy to .env and fill in your values before running

# ── Required ──────────────────────────────────────────────────────────────────

# Google Gemini API key (free tier available at https://aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key-here

# Google Cloud credentials JSON (for STT + TTS)
# Download from: GCP Console → IAM → Service Accounts → Keys
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# Audio sample rate: 8000 | 16000 | 24000 (Hz)
# Exotel default is 8000. Use 16000 for better quality voicebot.
SAMPLE_RATE=8000

# BCP-47 language code for STT and TTS
LANGUAGE_CODE=en-US

# Google TTS voice name (see https://cloud.google.com/text-to-speech/docs/voices)
TTS_VOICE=en-US-Neural2-F

# Server port
PORT=8000

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Enable uvicorn hot-reload (development only)
RELOAD=false

# ── Voice Activity Detection (VAD) ────────────────────────────────────────────
# VAD reduces LLM calls by 90%+ by batching audio into complete utterances

# Enable VAD-based buffering (recommended: true)
VAD_ENABLED=true

# Silence threshold in milliseconds before flushing buffer
# Lower = more responsive but may cut off speech
# Higher = safer but slower response
# Recommended: 500-1000ms (default: 700ms)
VAD_SILENCE_THRESHOLD_MS=700

# VAD sensitivity level: 0 (least) to 3 (most aggressive)
# 0 = Only very clear speech (fewest false positives)
# 1 = Normal sensitivity
# 2 = More sensitive (recommended for telephony with background noise)
# 3 = Most sensitive (may trigger on ambient noise)
VAD_SENSITIVITY=2

# Maximum buffer duration in seconds (safety limit)
# Prevents memory overflow during long monologues
MAX_SPEECH_BUFFER_SECONDS=30

# Enable "thinking" indicator during processing
# Sends beep/tone while waiting for LLM response
ENABLE_THINKING_INDICATOR=false

